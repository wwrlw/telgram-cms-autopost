{
    "name": "telegram-parser-api",
    "version": "1.0.0",
    "description": "clean architecture of backend service for parser and admin panel",
    "main": "index.js",
    "author": "me",
    "dependencies": {
        "@fastify/cors": "^11.0.1",
        "bcrypt": "^5.0.1",
        "config-yaml": "^1.1.6",
        "fastify": "^3.25.3",
        "fastify-cors": "^6.0.2",
        "fastify-jwt": "^4.1.3",
        "fastify-plugin": "^3.0.0",
        "joi": "^17.5.0",
        "mongodb": "^6.17.0",
        "mongoose": "^8.16.0",
        "pino-pretty": "^7.3.0"
    },
    "scripts": {
        "build": "tsc",
        "build-dev": "npm run build && NODE_ENV=development node --inspect dist/server.js",
        "dev": "nodemon --ext ts --exec \"npm run build-dev\"",
        "start": "npm run build && NODE_ENV=production node dist/server.js",
        "prettier:check": "prettier --check 'src/**/*.ts'",
        "prettier:fix": "prettier --write 'src/**/*.ts'"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.0",
        "@types/config-yaml": "^1.1.1",
        "@types/node": "^17.0.8",
        "dotenv": "^10.0.0",
        "nodemon": "^2.0.15",
        "prettier": "^2.5.1",
        "ts-node": "^10.4.0",
        "tsconfig-paths": "^3.12.0",
        "typescript": "^5.8.3"
    }
}
