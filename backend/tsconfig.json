{
    "compilerOptions": {
      "module": "commonjs",
      "declaration": true,
      "removeComments": true,
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "strictPropertyInitialization": false,
      "target": "ES2020",
      "sourceMap": true,
      "lib": ["ES2020"],
      "types": ["node"],
      "outDir": "./dist",
      "baseUrl": ".",
      "incremental": false,
      "strict": false,
      "esModuleInterop": true,
      "noEmit": false,
      "paths": {
        "~/*": ["src/*"]
      }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": ["node_modules", "dist"]
  }